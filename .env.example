# API Settings
API_V1_STR=/api/v1
PROJECT_NAME="Snowflake Security Toolkit Platform"

# Security
SECRET_KEY=snowflakesecuritytoolkitsecretkey12345
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Database
